// Sample VS Code settings for a Python project Testing using micromamba
// Put in the `.vscode/settings.json` file in your project root
// View > Command Palette or by pressing Ctrl+Shift+P -> "Test: Refresh Tests"
// Ref: https://pytest-with-eric.com/introduction/how-to-run-pytest-in-vscode/
//
// Clean State Reset (If Still Broken)
// pkill -f vscode-server
// cd ~/.vscode-server
{
    // "terminal.integrated.shell.linux": "/bin/bash",
    // "terminal.integrated.profiles.linux": {
    //     "bash": {
    //         "path": "/bin/bash"
    //     }
    // },
    // "terminal.integrated.defaultProfile.linux": "bash",
    // "python.testing.pytestPath": "/root/micromamba/envs/py311/bin/pytest",
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python.defaultInterpreterPath": "/root/micromamba/envs/py311/bin/python",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    // https://code.visualstudio.com/docs/python/environments#_package-managers-by-environment
    // "python-envs.pythonProjects": [
    //     {
    //     "path": "ml-service",
    //     "envManager": "ms-python.python:conda"
    //     }
    // ],
    // "files.autoSave": "onFocusChange",
    // "[python]": {
    //     "editor.defaultFormatter": "ms-python.black-formatter"
    // },
    // "python.testing.pytestArgs": ["."],
    // "python.testing.cwd": "${workspaceFolder}/tests",
    // "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "C_Cpp.errorSquiggles": "disabled"
}
