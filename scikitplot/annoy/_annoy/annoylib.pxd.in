# cython: wraparound=False, nonecheck=False, boundscheck=False, cdivision=True, language_level=3, binding=True, embedsignature=True
# cython: warn.unused=False
# distutils: language = c++
# distutils: extra_compile_args = -std=c++14 -O3 -march=native -DNDEBUG -pthread -DANNOYLIB_MULTITHREADED_BUILD
# distutils: extra_link_args = -std=c++14
#
# scikitplot/annoy/_annoy/annoylib.pxd.in
#
# cython annoylib.pyx --cplus
# g++ -std=c++14 -O3 -fPIC -DANNOYLIB_MULTITHREADED_BUILD -pthread \
#     -c annoylib.cpp -o annoylib.o
# g++ -shared annoylib.o -lpthread -o annoylib.so

"""
Cython Declaration File for Annoy C++ Library - Template Generated.

THIS FILE IS A TEMPLATE (.pxd.in) - The actual .pxd file is generated via Tempita.

Design Principles:

1. **Explicit Type Declarations**: All C++ types explicitly declared
2. **Safe Memory Management**: Proper pointer handling with nogil where safe
3. **Error Propagation**: char** error pattern for C++ exceptions
4. **Platform Compatibility**: Windows, Linux, macOS support
5. **Template Generation**: Auto-generate all type combinations via Tempita

Type System:

* S (index type): int32_t, int64_t (item/node identifiers)
* T (data type): float, double (embedding values)
* Distance: {Angular, Euclidean, Manhattan, DotProduct} metric classes
* InternalT: uint64_t (for HammingWrapper bit packing)
* Random: Kiss64Random (RNG type)
* ThreadedBuildPolicy: AnnoyIndexThreadedBuildPolicy

Template Parameters:

* index_types: List of (name, ctype, description) for S parameter
* data_types: List of (name, ctype, numpy_dtype, bits, description) for T parameter
* annoy_metrics: List of (name, class, description) for Distance parameter
* hamming_internal_types: List of (name, ctype, bits, description) for InternalT parameter

Generated Typedefs:

* AnnoyIndex types: 2 S × 2 T × 4 metrics = 16 types
* HammingWrapper types: 2 S × 2 T × 1 InternalT = 4 types
* Total: 20 concrete index types

Notes
-----
* All methods that can throw C++ exceptions use char** error parameter
* nogil blocks are used only for pure computational methods
* GIL is held during Python object manipulation

🧠 What .pxd Is Allowed To Contain - C-level declaration headers
Allowed:
    - cdef enum
    - cdef struct
    - cdef cppclass
    - cdef extern
    - cdef inline functions that are pure C-level
Not allowed:
    - Returning str
    - Raising ValueError
    - Creating Python objects
    - Runtime Python logic

Code Type                    Where It Goes     Why
Python dict {}               .pyx              Runtime Python objects
Function raising exception   .pyx              Python runtime feature
Pure C cdef inline           .pxd              No Python objects/exceptions
cdef extern                  .pxd              C/C++ declarations
cdef enum/struct             .pxd              Type declarations

References:
    - annoylib.h: C++ template implementation
    - https://en.cppreference.com/w/cpp/types/integer.html
    - https://cython-guidelines.readthedocs.io/en/latest/articles/lie.html
    - Cython fused types: https://cython.readthedocs.io/en/latest/src/userguide/fusedtypes.html
    - https://docs.cython.org/en/latest/src/userguide/wrapping_CPlusPlus.html#templates
"""

from libc.stdint cimport int32_t, int64_t, uint32_t, uint64_t, uint8_t
from libcpp cimport bool as cpp_bool
from libcpp.string cimport string as cpp_string
from libcpp.pair cimport pair as cpp_pair
from libcpp.vector cimport vector as cpp_vector
from libcpp.unordered_map cimport unordered_map

# ==============================================================================
# KISS Random Number Generator Interface
# ==============================================================================

cdef extern from "../../cexternals/_annoy/src/kissrandom.h" namespace "Annoy" nogil:

    # 64-bit KISS random generator (used by default)
    cdef cppclass Kiss64Random nogil:
        # Type aliases
        ctypedef uint64_t result_type

        # Constants
        @staticmethod
        uint64_t default_seed

        # Constructors
        Kiss64Random() except +
        Kiss64Random(uint64_t seed) except +

        # Core methods
        void reset(uint64_t seed) except +
        void reset_default() except +
        void set_seed(uint64_t seed) except +
        uint64_t kiss() except +
        int flip() except +
        size_t index(size_t n) except +

        # Static helpers
        @staticmethod
        uint64_t get_default_seed() nogil

        @staticmethod
        uint64_t normalize_seed(uint64_t seed) nogil

# ==============================================================================
# Annoy Index Interface (Base Class)
# ==============================================================================

cdef extern from "../../cexternals/_annoy/src/annoylib.h" namespace "Annoy" nogil:

    # Base interface
    # AnnoyAngularInt32FloatIndex
    #     ↓
    # AnnoyIndex<...>
    #     ↓
    # AnnoyIndexInterface<...>  (bridges _w → typed S/T/R methods)
    #     ↓
    # AnnoyIndexInterfaceBase   (owns ptr; all Cython calls go through here)
    #
    # Type-independent methods call directly via vtable.
    # Type-dependent methods use widened wire types (_w suffix):
    #   S → int64_t   T → double   R → uint64_t
    # Bridge implementations in AnnoyIndexInterface<S,T,R> do the casts.
    cdef cppclass AnnoyIndexInterfaceBase nogil:

        # ── Dimension (type-independent) ──────────────────────────────────
        int      get_f()                                   nogil
        cpp_bool set_f(int f, char** error)                except +

        # ── Configuration (type-independent) ──────────────────────────────
        void set_verbose(cpp_bool v)                       except +

        # ── Core operations (type-independent) ────────────────────────────
        cpp_bool build(int n_trees, int n_threads, char** error) except +
        cpp_bool unbuild(char** error)                     except +

        # ── Persistence Disk I/O (type-independent) ───────────────────────
        cpp_bool save(const char* filename, cpp_bool prefault,
                      char** error)                        except +
        cpp_bool load(const char* filename, cpp_bool prefault,
                      char** error)                        except +
        cpp_bool on_disk_build(const char* filename,
                               char** error)               except +
        void     unload()                                  except +

        # ── Serialisation Persistence (Memory) (type-independent) ─────────
        cpp_vector[uint8_t] serialize(char** error)        except +
        cpp_bool deserialize(cpp_vector[uint8_t]* bytes,
                             cpp_bool prefault, char** error) except +

        # ── Sklearn compatibility (type-independent) ──────────────────────
        cpp_bool get_params(
            cpp_vector[cpp_pair[cpp_string, cpp_string]]& params
        ) except +
        cpp_bool set_params(
            const cpp_vector[cpp_pair[cpp_string, cpp_string]]& params,
            char** error
        ) except +

        # ── Configuration ─────────────────────────────────────────────────

        # void set_seed(Random seed) except +
        void set_seed_w(uint64_t seed)                     except +

        # ==================== Core Building ====================
        # cpp_bool add_item(S item, const T* embedding, char** error) except +

        # ── Widened mutators (_w) ─────────────────────────────────────────
        cpp_bool add_item_w(int64_t item, const double* emb,
                            char** error)                  except +

        # ==================== Metadata ====================

        # S get_n_items() nogil
        # S get_n_trees() nogil
        # T get_distance(S i, S j) except +
        # void get_item(S item, T* embedding) except +

        # ── Widened accessors (_w) ────────────────────────────────────────
        int64_t get_n_items_w()                            nogil
        int64_t get_n_trees_w()                            nogil
        double  get_distance_w(int64_t i, int64_t j)       except +
        void    get_item_w(int64_t item, double* emb)      except +

        # ==================== Querying ====================

        # void get_nns_by_item(
        #     S item,
        #     size_t n,
        #     int search_k,
        #     cpp_vector[S]* result,
        #     cpp_vector[T]* distances
        # ) except +
        # void get_nns_by_vector(
        #     const T* embedding,
        #     size_t n,
        #     int search_k,
        #     cpp_vector[S]* result,
        #     cpp_vector[T]* distances
        # ) except +

        # ── Widened queries (_w) ──────────────────────────────────────────
        void get_nns_by_item_w(
            int64_t item, size_t n, int search_k,
            cpp_vector[int64_t]* result,
            cpp_vector[double]*  distances
        ) except +

        void get_nns_by_vector_w(
            const double* vec, size_t n, int search_k,
            cpp_vector[int64_t]* result,
            cpp_vector[double]*  distances
        ) except +

    # Base interface for all Annoy index types
    cdef cppclass AnnoyIndexInterface[S, T, Random](AnnoyIndexInterfaceBase) nogil:
        """
        Abstract base interface for Annoy indices.

        Lifecycle
        ---------
        1. Construction: AnnoyIndex(f) where f > 0
        2. Building: add_item() repeatedly, then build()
        3. Querying: get_nns_by_item(), get_nns_by_vector()
        4. Persistence: save(), load(), serialize(), deserialize()
        5. Destruction: unload(), then delete

        State Transitions
        -----------------
        * EMPTY → BUILDING: first add_item()
        * BUILDING → BUILT: build()
        * BUILT → BUILDING: unbuild()
        * BUILT → LOADED: load()
        * Any → EMPTY: unload()
        """

        # ==================== Core Building ====================

        cpp_bool add_item(S item, const T* embedding, char** error) except +

        cpp_bool build(int n_trees, int n_threads, char** error) except +

        cpp_bool unbuild(char** error) except +

        # ==================== Querying ====================

        void get_nns_by_item(
            S item,
            size_t n,
            int search_k,
            cpp_vector[S]* result,
            cpp_vector[T]* distances
        ) except +

        void get_nns_by_vector(
            const T* embedding,
            size_t n,
            int search_k,
            cpp_vector[S]* result,
            cpp_vector[T]* distances
        ) except +

        T get_distance(S i, S j) except +

        void get_item(S item, T* embedding) except +

        # ==================== Metadata ====================

        S get_n_items() nogil

        S get_n_trees() nogil

        int get_f() nogil

        # ==================== Persistence (Disk) ====================

        cpp_bool save(const char* filename, cpp_bool prefault, char** error) except +

        cpp_bool load(const char* filename, cpp_bool prefault, char** error) except +

        cpp_bool on_disk_build(const char* filename, char** error) except +

        void unload() except +

        # ==================== Persistence (Memory) ====================

        cpp_vector[uint8_t] serialize(char** error) except +

        cpp_bool deserialize(cpp_vector[uint8_t]* bytes, cpp_bool prefault, char** error) except +

        # ==================== Configuration ====================

        void set_seed(Random seed) except +

        void set_verbose(cpp_bool v) except +

# ==============================================================================
# Concrete Annoy Index Types (Metric-Specific) - TEMPLATE GENERATED
# ==============================================================================

cdef extern from "../../cexternals/_annoy/src/annoylib.h" namespace "Annoy" nogil:

    # Forward declarations of metric types (defined in annoylib.h)
    cdef cppclass Angular nogil:
        pass

    cdef cppclass Euclidean nogil:
        pass

    cdef cppclass Manhattan nogil:
        pass

    cdef cppclass DotProduct nogil:
        pass

    cdef cppclass Hamming nogil:
        pass

    # Build policy types
    cdef cppclass AnnoyIndexSingleThreadedBuildPolicy nogil:
        pass

    cdef cppclass AnnoyIndexThreadedBuildPolicy nogil:
        pass

    # Generic AnnoyIndex template
    cdef cppclass AnnoyIndex[S, T, Distance, Random, ThreadedBuildPolicy](AnnoyIndexInterface[S, T, Random]) nogil:
        """
        Generic templated Annoy index.

        Template Parameters
        -------------------
        S : {int32_t, int64_t}
            Index type
        T : {float, double}
            Data type
        Distance : {Angular, Euclidean, Manhattan, DotProduct}
            Metric type
        Random : Kiss64Random
            RNG type
        ThreadedBuildPolicy : {Single, Multi}ThreadedBuildPolicy
            Threading strategy
        """

        AnnoyIndex() except +
        AnnoyIndex(int f) except +

    # Hamming wrapper (special case: packs float embeddings into binary)
    cdef cppclass HammingWrapper[S, T, InternalT, Random, ThreadedBuildPolicy](AnnoyIndexInterface[S, T, Random]) nogil:
        """
        Hamming metric wrapper with float-to-binary packing.

        Embedding Interpretation
        ------------------------
        * Input: float/double array of length f
        * Each value is thresholded: val >= 0.5 → 1, else → 0
        * Packed into InternalT words for efficient XOR
        * Distance is Hamming distance (popcount of XOR)
        * Distance is clipped to [0, f]

        Memory Layout
        -------------
        * f_external: user-facing dimension (float array length)
        * f_internal: packed dimension (ceil(f_external / bits_per_word))
        * Storage: f_internal * sizeof(InternalT) bytes per vector
        """

        HammingWrapper() except +
        HammingWrapper(int f) except +

    # ==============================================================================
    # GENERATED TYPEDEFS - AnnoyIndex Types
    # ==============================================================================

{{py:

# Type configuration for template generation
index_types = [
    {'name': 'Int32', 'ctype': 'int32_t', 'description': '32-bit signed integer (max 2^31-1 items)'},
    {'name': 'Int64', 'ctype': 'int64_t', 'description': '64-bit signed integer (max 2^63-1 items)'},
]

data_types = [
    {'name': 'Float', 'ctype': 'float', 'numpy_dtype': 'float32', 'bits': 32, 'description': 'Single precision (32-bit)'},
    {'name': 'Double', 'ctype': 'double', 'numpy_dtype': 'float64', 'bits': 64, 'description': 'Double precision (64-bit)'},
]

annoy_metrics = [
    {'name': 'Angular', 'class': 'Angular', 'description': 'Cosine similarity (1 - cos(θ))'},
    {'name': 'Euclidean', 'class': 'Euclidean', 'description': 'L2 distance (Euclidean norm)'},
    {'name': 'Manhattan', 'class': 'Manhattan', 'description': 'L1 distance (city-block)'},
    {'name': 'DotProduct', 'class': 'DotProduct', 'description': 'Negative dot product (for MIPS)'},
]

hamming_internal_types = [
    {'name': 'Uint64', 'ctype': 'uint64_t', 'bits': 64, 'description': '64-bit unsigned integer for bit packing'},
]
}}

    # Generate AnnoyIndex typedefs for all metric/index/data combinations
    {{for metric in annoy_metrics}}
    {{for index_type in index_types}}
    {{for data_type in data_types}}
    # {{metric['description']}} with {{index_type['description']}} and {{data_type['description']}}
    ctypedef AnnoyIndex[{{index_type['ctype']}}, {{data_type['ctype']}}, {{metric['class']}}, Kiss64Random, AnnoyIndexThreadedBuildPolicy] \
        Annoy{{metric['name']}}{{index_type['name']}}{{data_type['name']}}Index \
        "Annoy::AnnoyIndex<{{index_type['ctype']}}, {{data_type['ctype']}}, Annoy::{{metric['class']}}, Annoy::Kiss64Random, Annoy::AnnoyIndexThreadedBuildPolicy>"

    {{endfor}}
    {{endfor}}
    {{endfor}}

    # ==============================================================================
    # GENERATED TYPEDEFS - HammingWrapper Types
    # ==============================================================================

    # Generate HammingWrapper typedefs for all index/data combinations
    {{for index_type in index_types}}
    {{for data_type in data_types}}
    {{for internal_type in hamming_internal_types}}
    # Hamming distance with {{index_type['description']}}, {{data_type['description']}}, {{internal_type['description']}}
    ctypedef HammingWrapper[{{index_type['ctype']}}, {{data_type['ctype']}}, {{internal_type['ctype']}}, Kiss64Random, AnnoyIndexThreadedBuildPolicy] \
        AnnoyHamming{{index_type['name']}}{{data_type['name']}}{{internal_type['name']}}Index \
        "Annoy::HammingWrapper<{{index_type['ctype']}}, {{data_type['ctype']}}, {{internal_type['ctype']}}, Annoy::Kiss64Random, Annoy::AnnoyIndexThreadedBuildPolicy>"

    {{endfor}}
    {{endfor}}
    {{endfor}}

