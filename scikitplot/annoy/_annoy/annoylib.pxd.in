cdef extern from "<cstdlib>" namespace "std" nogil:

    void free(void* ptr)

# strdup is POSIX (::strdup), not std::strdup.
# annoylib.h includes <string.h> and provides the MSVC _strdup alias, so
# using <string.h> with no namespace qualifier matches the C++ side exactly.
cdef extern from "<string.h>" nogil:

    char* strdup(const char* s)
