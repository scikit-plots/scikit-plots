cdef extern from "../../cexternals/_annoy/src/annoylib.h" namespace "Annoy" nogil:

    # Base interface
    # AnnoyAngularInt32FloatIndex
    #     ↓
    # AnnoyIndex<...>
    #     ↓
    # AnnoyIndexInterface<...>  (bridges _w → typed S/T/R methods)
    #     ↓
    # AnnoyIndexInterfaceBase   (owns ptr; all Cython calls go through here)
    #
    # Type-independent methods call directly via vtable.
    # Type-dependent methods use widened wire types (_w suffix):
    #   S → uint64_t   T → double   R → uint64_t
    # Bridge implementations in AnnoyIndexInterface<S,T,R> do the casts.
    cdef cppclass AnnoyIndexInterfaceBase nogil:

        # ── Dimension (type-independent) ──────────────────────────────────
        int      get_f()                                   nogil
        cpp_bool set_f(int f, char** error)                except +

        # ── Configuration (type-independent) ──────────────────────────────
        void set_verbose(cpp_bool v)                       except +

        # ── Core operations (type-independent) ────────────────────────────
        cpp_bool build(int n_trees, int n_threads, char** error) except +
        cpp_bool unbuild(char** error)                     except +

        # ── Persistence Disk I/O (type-independent) ───────────────────────
        cpp_bool save(const char* filename, cpp_bool prefault,
                      char** error)                        except +
        cpp_bool load(const char* filename, cpp_bool prefault,
                      char** error)                        except +
        cpp_bool on_disk_build(const char* filename,
                               char** error)               except +
        void     unload()                                  except +

        # ── Serialisation Persistence (Memory) (type-independent) ─────────
        cpp_vector[uint8_t] serialize(char** error)        except +
        cpp_bool deserialize(cpp_vector[uint8_t]* bytes,
                             cpp_bool prefault, char** error) except +

        # ── Sklearn compatibility (type-independent) ──────────────────────
        cpp_bool get_params(
            cpp_vector[cpp_pair[cpp_string, cpp_string]]& params
        ) except +
        cpp_bool set_params(
            const cpp_vector[cpp_pair[cpp_string, cpp_string]]& params,
            char** error
        ) except +

        # ── Configuration ─────────────────────────────────────────────────

        # void set_seed(Random seed) except +
        void set_seed_w(uint64_t seed)                     except +

        # ==================== Core Building ====================
        # cpp_bool add_item(S item, const T* embedding, char** error) except +

        # ── Widened mutators (_w) ─────────────────────────────────────────
        cpp_bool add_item_w(uint64_t item, const double* emb,
                            char** error)                  except +

        # ==================== Metadata ====================

        # S get_n_items() nogil
        # S get_n_trees() nogil
        # T get_distance(S i, S j) except +
        # void get_item(S item, T* embedding) except +

        # ── Widened accessors (_w) ────────────────────────────────────────
        uint64_t get_n_items_w()                            nogil
        uint64_t get_n_trees_w()                            nogil
        double  get_distance_w(uint64_t i, uint64_t j)      except +
        void    get_item_w(uint64_t item, double* emb)      except +

        # ==================== Querying ====================

        # void get_nns_by_item(
        #     S item,
        #     size_t n,
        #     int search_k,
        #     cpp_vector[S]* result,
        #     cpp_vector[T]* distances
        # ) except +
        # void get_nns_by_vector(
        #     const T* embedding,
        #     size_t n,
        #     int search_k,
        #     cpp_vector[S]* result,
        #     cpp_vector[T]* distances
        # ) except +

        # ── Widened queries (_w) ──────────────────────────────────────────
        void get_nns_by_item_w(
            uint64_t item, size_t n, int search_k,
            cpp_vector[uint64_t]* result,
            cpp_vector[double]*  distances
        ) except +

        void get_nns_by_vector_w(
            const double* vec, size_t n, int search_k,
            cpp_vector[uint64_t]* result,
            cpp_vector[double]*  distances
        ) except +

    # Base interface for all Annoy index types
    cdef cppclass AnnoyIndexInterface[S, T, Random](AnnoyIndexInterfaceBase) nogil:
        """
        Abstract base interface for Annoy indices.

        Lifecycle
        ---------
        1. Construction: AnnoyIndex(f) where f > 0
        2. Building: add_item() repeatedly, then build()
        3. Querying: get_nns_by_item(), get_nns_by_vector()
        4. Persistence: save(), load(), serialize(), deserialize()
        5. Destruction: unload(), then delete

        State Transitions
        -----------------
        * EMPTY → BUILDING: first add_item()
        * BUILDING → BUILT: build()
        * BUILT → BUILDING: unbuild()
        * BUILT → LOADED: load()
        * Any → EMPTY: unload()
        """

        # ==================== Core Building ====================

        cpp_bool add_item(S item, const T* embedding, char** error) except +

        cpp_bool build(int n_trees, int n_threads, char** error) except +

        cpp_bool unbuild(char** error) except +

        # ==================== Querying ====================

        void get_nns_by_item(
            S item,
            size_t n,
            int search_k,
            cpp_vector[S]* result,
            cpp_vector[T]* distances
        ) except +

        void get_nns_by_vector(
            const T* embedding,
            size_t n,
            int search_k,
            cpp_vector[S]* result,
            cpp_vector[T]* distances
        ) except +

        T get_distance(S i, S j) except +

        void get_item(S item, T* embedding) except +

        # ==================== Metadata ====================

        S get_n_items() nogil

        S get_n_trees() nogil

        int get_f() nogil

        # ==================== Persistence (Disk) ====================

        cpp_bool save(const char* filename, cpp_bool prefault, char** error) except +

        cpp_bool load(const char* filename, cpp_bool prefault, char** error) except +

        cpp_bool on_disk_build(const char* filename, char** error) except +

        void unload() except +

        # ==================== Persistence (Memory) ====================

        cpp_vector[uint8_t] serialize(char** error) except +

        cpp_bool deserialize(cpp_vector[uint8_t]* bytes, cpp_bool prefault, char** error) except +

        # ==================== Configuration ====================

        void set_seed(Random seed) except +

        void set_verbose(cpp_bool v) except +

