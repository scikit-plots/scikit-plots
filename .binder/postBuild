#!/usr/bin/env bash
# shellcheck shell=bash
# postBuild — repo2docker post-build script for scikit-plots/.binder
#
# PURPOSE
#   Converts scikit-plots Python gallery examples into Jupyter notebooks,
#   configures the Binder workspace directory layout, and enables
#   Jupyter notebook extensions for the Binder environment.
#
# CONTRACT
#   Input  : WORKDIR must be the root of a git repository containing
#            galleries/examples/ and .binder/
#   Output : WORKDIR contains .generated-notebooks/ with .ipynb files
#            and notebooks/auto_examples -> ../.generated-notebooks symlink
#   Side effects: WORKDIR is cleared and rebuilt; all content is backed up
#                 to a unique temp directory first and restored on exit.
#
# INVARIANTS
#   - Must run inside a repo2docker build context (REPO_DIR is set)
#   - WORKDIR must be inside a git repository (repo content, not system paths)
#   - Temp directory is always removed on exit regardless of outcome
#   - WORKDIR is only cleared AFTER all backups are verified
#
# FAILURE MODES
#   - REPO_DIR not set            : exit 1, no data touched
#   - WORKDIR not a git repo      : exit 1, no data touched
#   - Missing required command    : exit 1, no data touched
#   - Missing source directory    : exit 1, no data touched
#   - Backup verification fails   : exit 1, no data touched
#   - Post-deletion failure       : cleanup trap removes temp; WORKDIR is empty
#                                   (irrecoverable — inspect the build logs)
#   - OpenBLAS install failure    : logged as warning; script succeeds
#   - Jupyter extension failure   : exit 1
#
# ENVIRONMENT
#   REPO_DIR                Set by repo2docker at build time. Required.
#   SCIPY_OPENBLAS_VARIANT  32 | 64 | auto (default: auto)

set -Eeuo pipefail
IFS=$'\n\t'

# Ignore SIGPIPE so the script is not killed when output is piped to a tool
# that closes its stdin early (e.g. head, less, tee into a closed descriptor).
trap '' PIPE

printf '[start] INFO  Binder session postBuild...\n' >&2

# ─────────────────────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_NAME="$(basename -- "$0")"
readonly SCRIPT_NAME

# Use ${PWD} rather than $(pwd) — avoids a subshell and is always set by bash.
readonly WORKDIR="${PWD}"

# TMP_ROOT is populated by prepare_workspace() via mktemp -d so that concurrent
# builds each get a unique directory and cannot interfere with each other.
# Declared here (not readonly) so that cleanup() can reference it even before
# prepare_workspace() runs.
TMP_ROOT=""

readonly GENERATED_NOTEBOOKS_DIR="${WORKDIR}/.generated-notebooks"
readonly NOTEBOOKS_LINK="${WORKDIR}/notebooks/auto_examples"

# ─────────────────────────────────────────────────────────────────────────────
# Logging — all output goes to stderr so it does not pollute captured stdout
# ─────────────────────────────────────────────────────────────────────────────

log_info()  { printf '[%s] INFO  %s\n' "${SCRIPT_NAME}" "$*" >&2; }
log_warn()  { printf '[%s] WARN  %s\n' "${SCRIPT_NAME}" "$*" >&2; }
log_error() { printf '[%s] ERROR %s\n' "${SCRIPT_NAME}" "$*" >&2; }

# ─────────────────────────────────────────────────────────────────────────────
# Cleanup — runs on EXIT, INT, and TERM
# ─────────────────────────────────────────────────────────────────────────────

cleanup() {
    local exit_code=$?
    set +e
    if [[ -n "${TMP_ROOT}" && -d "${TMP_ROOT}" ]]; then
        log_info "Removing temp directory: ${TMP_ROOT}"
        rm -rf -- "${TMP_ROOT}"
    fi
    exit "${exit_code}"
}

trap cleanup EXIT
# Translate signals to predictable exit codes so cleanup() receives the right
# value via $?. The 128+N convention is the POSIX standard for signal exits.
trap 'exit 130' INT    # 128 + 2  (SIGINT)
trap 'exit 143' TERM   # 128 + 15 (SIGTERM)

# ─────────────────────────────────────────────────────────────────────────────
# Guards — checked before any destructive operation
# ─────────────────────────────────────────────────────────────────────────────

assert_repo2docker() {
    # REPO_DIR is injected by repo2docker as a build-time environment variable.
    # Its presence is the authoritative signal that we are running inside a
    # repo2docker build context, where it is safe to clear and rebuild WORKDIR.
    # This is the same check used by scikit-learn's canonical postBuild.
    if [[ -z "${REPO_DIR:-}" ]]; then
        log_error "REPO_DIR is not set."
        log_error "This script must run inside a repo2docker build context."
        log_error "Exiting: running outside repo2docker can delete important data."
        exit 1
    fi
    log_info "repo2docker context confirmed (REPO_DIR=${REPO_DIR})."
}

assert_git_repo() {
    # Confirm WORKDIR is inside a git repository.
    # repo2docker clones the target repo into REPO_DIR and runs postBuild
    # with cwd = REPO_DIR. The presence of a .git tree confirms we are
    # operating on repo content (e.g. /home/jovyan/scikit-plots,
    # /work/scikit-plots), not an arbitrary system directory.
    if ! git -C "${WORKDIR}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        log_error "WORKDIR='${WORKDIR}' is not inside a git repository."
        log_error "Refusing to clear its contents."
        exit 1
    fi
    log_info "Git repository confirmed: ${WORKDIR}"
}

require_command() {
    # $1 : command name to check
    local cmd="$1"
    command -v "${cmd}" >/dev/null 2>&1 || {
        log_error "Required command not found on PATH: ${cmd}"
        exit 1
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Workspace setup
# ─────────────────────────────────────────────────────────────────────────────

prepare_workspace() {
    # mktemp -d creates a uniquely named directory, preventing race conditions
    # when multiple builds run concurrently on the same host.
    TMP_ROOT="$(mktemp -d -t "scikit-plots-build.XXXXXX")"
    log_info "Temp workspace: ${TMP_ROOT}"
}

backup_required_content() {
    # Developer note: source paths are inside WORKDIR; destinations are inside
    # TMP_ROOT. Backup directory names are canonical — generate_notebooks() and
    # restore_binder_assets() must use the exact same names.
    local tmp_examples="${TMP_ROOT}/examples"
    local tmp_binder="${TMP_ROOT}/.binder"
    local src_examples="${WORKDIR}/galleries/examples"
    local src_binder="${WORKDIR}/.binder"

    [[ -d "${src_examples}" ]] || {
        log_error "Source directory missing: ${src_examples}"
        exit 1
    }
    [[ -d "${src_binder}" ]] || {
        log_error "Source directory missing: ${src_binder}"
        exit 1
    }

    log_info "Backing up examples -> ${tmp_examples}"
    cp -a -- "${src_examples}" "${tmp_examples}"

    log_info "Backing up .binder -> ${tmp_binder}"
    cp -a -- "${src_binder}" "${tmp_binder}"

    # Verify backup completeness before any destructive step.
    # If either check fails, set -e aborts here and WORKDIR is untouched.
    [[ -d "${tmp_examples}" ]] || { log_error "Backup of examples failed."; exit 1; }
    [[ -d "${tmp_binder}"   ]] || { log_error "Backup of .binder failed.";  exit 1; }
    log_info "Backup verified."

    # Clear all repo content from WORKDIR.
    # ${WORKDIR:?} is a parameter guard: if WORKDIR is unset or empty, bash
    # aborts before find runs — preventing accidental deletion from the wrong path.
    # -mindepth 1 preserves the WORKDIR directory itself so the build layer
    # stays valid. -delete enables post-order traversal automatically (equivalent
    # to -depth), which is correct: leaf entries are removed before their parents.
    log_info "Clearing WORKDIR: ${WORKDIR}"
    find "${WORKDIR:?}" -mindepth 1 -delete
    # delete everything in current directory including dot files and dot folders
    # find . -delete
}

# ─────────────────────────────────────────────────────────────────────────────
# Notebook generation
# ─────────────────────────────────────────────────────────────────────────────

generate_notebooks() {
    # Developer note: source is ${TMP_ROOT}/examples (set by backup_required_content).
    local tmp_examples="${TMP_ROOT}/examples"

    rm -rf  -- "${GENERATED_NOTEBOOKS_DIR}"
    mkdir -p   "${GENERATED_NOTEBOOKS_DIR}"

    log_info "Staging example files -> ${GENERATED_NOTEBOOKS_DIR}"
    cp -a -- "${tmp_examples}/." "${GENERATED_NOTEBOOKS_DIR}/"

    local py_count
    py_count="$(find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.py' | wc -l)"
    log_info "Found ${py_count} Python gallery file(s) to convert."

    if (( py_count == 0 )); then
        log_warn "No .py files found — nothing to convert."
    else
        # Use -exec ... \; (one invocation per file) rather than -exec ... +
        # (batched). The \; form ensures that a failure on any individual file
        # is reported immediately with its filename, not silently absorbed into
        # a batch exit code.
        find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.py' \
            -exec sphinx_gallery_py2jupyter '{}' \;
    fi

    # Remove all non-notebook files from the staging directory.
    find "${GENERATED_NOTEBOOKS_DIR}" -type f ! -name '*.ipynb' -delete

    local nb_count
    nb_count="$(find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.ipynb' | wc -l)"
    log_info "Generated ${nb_count} notebook(s)."

    # If we had source files but produced no notebooks, the conversion failed.
    if (( py_count > 0 && nb_count == 0 )); then
        log_error "sphinx_gallery_py2jupyter produced 0 notebooks from ${py_count} .py files."
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Restore binder assets and symlinks
# ─────────────────────────────────────────────────────────────────────────────

restore_binder_assets() {
    local tmp_binder="${TMP_ROOT}/.binder"

    [[ -d "${tmp_binder}" ]] || {
        log_error "Backed-up .binder not found at: ${tmp_binder}"
        exit 1
    }

    log_info "Restoring .binder -> ${WORKDIR}/.binder"
    rm -rf -- "${WORKDIR}/.binder"

    # cp -a preserves UID/GID and file integrity.
    # mv(1) fails with EXDEV when source and destination are on different
    # filesystems (e.g. /tmp on tmpfs vs WORKDIR on overlayfs inside Docker
    # build layers). cp -a + rm avoids that cross-device restriction.
    cp -a  -- "${tmp_binder}" "${WORKDIR}/.binder"
    rm -rf -- "${tmp_binder}"

    [[ -d "${WORKDIR}/.binder" ]] || {
        log_error "Failed to restore .binder to ${WORKDIR}."
        exit 1
    }
    log_info ".binder restored."
}

setup_symlinks() {
    # sphinx-gallery generates binder launch URLs using the path
    # notebooks/auto_examples/<notebook>.ipynb relative to the repo root.
    # This symlink satisfies that expectation regardless of which repo is
    # checked out for binder (scikit-plots vs its documentation repo).
    mkdir -p -- "$(dirname -- "${NOTEBOOKS_LINK}")"
    ln -sfn -- "../.generated-notebooks" "${NOTEBOOKS_LINK}"
    log_info "Symlink: ${NOTEBOOKS_LINK} -> ../.generated-notebooks"
}

# ─────────────────────────────────────────────────────────────────────────────
# OpenBLAS
# ─────────────────────────────────────────────────────────────────────────────

install_openblas_variant() {
    # User note: set SCIPY_OPENBLAS_VARIANT=32 or =64 to pin a specific variant.
    # Defaults to 'auto': tries 64-bit first, falls back to 32-bit on failure.
    local variant="${SCIPY_OPENBLAS_VARIANT:-auto}"
    local package_name

    case "${variant}" in
        32)   package_name="scipy-openblas32" ;;
        64)   package_name="scipy-openblas64" ;;
        auto) package_name=""                 ;;
        *)
            log_error "Invalid SCIPY_OPENBLAS_VARIANT='${variant}'. Allowed values: 32 | 64 | auto"
            return 1
            ;;
    esac

    if [[ "${variant}" == "auto" ]]; then
        log_info "SCIPY_OPENBLAS_VARIANT=auto: trying scipy-openblas64 first."
        if python -m pip install --no-cache-dir scipy-openblas64 2>&1 \
                | sed 's/^/[pip] /'; then
            log_info "Installed scipy-openblas64."
            return 0
        fi
        log_warn "scipy-openblas64 unavailable; falling back to scipy-openblas32."
        if python -m pip install --no-cache-dir scipy-openblas32 2>&1 \
                | sed 's/^/[pip] /'; then
            log_info "Installed scipy-openblas32."
            return 0
        else
            log_warn "scipy-openblas32 installation also failed."
            return 1
        fi
    fi

    log_info "Installing ${package_name} (SCIPY_OPENBLAS_VARIANT=${variant})."
    python -m pip install --no-cache-dir "${package_name}" 2>&1 \
        | sed 's/^/[pip] /'
}

verify_openblas_install() {
    # Emit a warning (not an error) when neither variant is detectable.
    # Some environments use a system OpenBLAS that does not ship as a pip
    # package, so absence of these modules is not always a fatal condition.
    log_info "Verifying OpenBLAS installation."
    python - <<'PY'
import importlib.util, sys

found = [
    pkg for pkg in ("scipy_openblas32", "scipy_openblas64")
    if importlib.util.find_spec(pkg) is not None
]

if found:
    print("Detected:", ", ".join(found), flush=True)
else:
    print(
        "WARNING: neither scipy_openblas32 nor scipy_openblas64 detected.",
        file=sys.stderr,
    )
PY
}

# ─────────────────────────────────────────────────────────────────────────────
# Jupyter extensions
# ─────────────────────────────────────────────────────────────────────────────

setup_jupyter_extensions() {
    # Configures Jupyter Notebook (classic) extensions.
    # jupyter_contrib_nbextensions must be installed via requirements.txt or
    # environment.yml before this function runs.
    #
    # Developer note: `jupyter labextension install` was the JupyterLab 1.x/2.x
    # API and was completely removed in JupyterLab 4. Lab extensions are now
    # distributed as Python packages and auto-registered at pip-install time
    # (e.g. ipywidgets since 7.6). Do NOT add `jupyter labextension install`
    # calls here.
    log_info "Installing contrib notebook extensions (classic Notebook)."
    jupyter contrib nbextension install --user

    log_info "Enabling widgetsnbextension (classic Notebook)."
    jupyter nbextension enable --py widgetsnbextension
}

# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

main() {
    log_info "postBuild starting."

    # ── Guards (no side effects) ──────────────────────────────────────────────
    assert_repo2docker
    assert_git_repo
    require_command python
    require_command sphinx_gallery_py2jupyter

    # ── Main pipeline ─────────────────────────────────────────────────────────
    prepare_workspace
    backup_required_content    # backs up content; then clears WORKDIR
    generate_notebooks         # converts .py -> .ipynb inside WORKDIR
    restore_binder_assets      # puts .binder back into WORKDIR
    setup_symlinks             # creates notebooks/auto_examples -> symlink

    # ── Optional: OpenBLAS ───────────────────────────────────────────────────
    # install_openblas_variant is best-effort: failure is logged as a warning
    # rather than aborting the build, because the core notebook conversion has
    # already completed successfully at this point.
    if install_openblas_variant; then
        verify_openblas_install
    else
        log_warn "OpenBLAS installation failed; continuing without it."
        log_warn "Set SCIPY_OPENBLAS_VARIANT=32 or =64 to pin a specific variant."
    fi

    # ── Jupyter extensions ───────────────────────────────────────────────────
    # require_command jupyter
    # setup_jupyter_extensions

    log_info "postBuild completed successfully."
}

main "$@"
