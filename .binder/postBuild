#!/usr/bin/env bash
# shellcheck shell=bash

set -Eeuo pipefail
IFS=$'\n\t'

# This script is called in a binder context. When this script is called, we are
# inside a git checkout of the scikit-learn/scikit-learn repo. This script is
# generating notebooks from the scikit-learn python examples.

readonly SCRIPT_NAME="$(basename "$0")"
readonly WORKDIR="$(pwd)"
readonly TMP_ROOT="/tmp/scikit-plots-build"
readonly TMP_CONTENT_DIR="${TMP_ROOT}/content"
readonly GENERATED_NOTEBOOKS_DIR="${WORKDIR}/.generated-notebooks"

log() {
    printf '[%s] %s\n' "$SCRIPT_NAME" "$*"
}

cleanup() {
    if [[ -d "$TMP_ROOT" ]]; then
        rm -rf "$TMP_ROOT"
    fi
}
trap cleanup EXIT

require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        log "Missing required command: $1"
        exit 1
    }
}

assert_docker() {
    if [[ ! -f "/.dockerenv" ]]; then
        log "This script must run inside a Docker/repo2docker environment."
        log "Exiting because this script can delete data if run outside of a docker container."
        exit 1
    fi
}

prepare_workspace() {
    mkdir -p "$TMP_CONTENT_DIR"
}

backup_required_content() {
    local source_examples="${WORKDIR}/galleries/examples"
    local source_binder="${WORKDIR}/.binder"

    [[ -d "$source_examples" ]] || { log "Missing examples directory"; exit 1; }
    [[ -d "$source_binder" ]] || { log "Missing .binder directory"; exit 1; }

    # Back up content we need from the scikit-plots repo
    cp -r "$source_examples" "$TMP_CONTENT_DIR/"
    cp -r "$source_binder" "$TMP_CONTENT_DIR/"
    # delete everything in current directory including dot files and dot folders
    find . -delete
}

generate_notebooks() {
    rm -rf "$GENERATED_NOTEBOOKS_DIR"
    mkdir -p "$GENERATED_NOTEBOOKS_DIR"

    # Generate notebooks and remove other files from examples folder
    cp -r "$TMP_CONTENT_DIR/galleries/examples/." "$GENERATED_NOTEBOOKS_DIR/"

    find "$GENERATED_NOTEBOOKS_DIR" -type f -name '*.py' \
        -exec sphinx_gallery_py2jupyter '{}' +

    find "$GENERATED_NOTEBOOKS_DIR" -type f ! -name '*.ipynb' -delete
    # NON_NOTEBOOKS=$(find $GENERATED_NOTEBOOKS_DIR -type f | grep -v '\.ipynb')
    # rm -f $NON_NOTEBOOKS
}

restore_binder_assets() {
    # Put the .binder folder back (may be useful for debugging purposes)
    rm -rf "${WORKDIR}/.binder"
    mv "$TMP_CONTENT_DIR/.binder" "$WORKDIR/.binder"
    # Final clean up
    rm -rf $TMP_CONTENT_DIR
}

setup_symlinks() {
    # This is for compatibility with binder sphinx-gallery integration: this makes
    # sure that the binder links generated by sphinx-gallery are correct even tough
    # the repo we use for binder (scikit-learn/scikit-learn) is not the repo of the
    # generated doc (scikit-learn/scikit-learn.github.io)
    mkdir -p "${WORKDIR}/notebooks"
    ln -sfn "../.generated-notebooks" "${WORKDIR}/notebooks/auto_examples"
}

install_openblas_variant() {
    # export SCIPY_OPENBLAS_VARIANT=64
    # export SCIPY_OPENBLAS_VARIANT=32
    local variant="${SCIPY_OPENBLAS_VARIANT:-auto}"
    local package_name=""

    case "$variant" in
        32)
            package_name="scipy-openblas32"
            ;;
        64)
            package_name="scipy-openblas64"
            ;;
        auto)
            # Prefer 64-bit, fallback to 32-bit
            if python -m pip install --no-cache-dir scipy-openblas64; then
                log "Installed scipy-openblas64"
                return 0
            fi

            log "Falling back to scipy-openblas32"
            python -m pip install --no-cache-dir scipy-openblas32
            return 0
            ;;
        *)
            log "Invalid SCIPY_OPENBLAS_VARIANT: $variant"
            log "Allowed values: 32 | 64 | auto"
            exit 1
            ;;
    esac

    log "Installing ${package_name}"
    python -m pip install --no-cache-dir "$package_name"
}

verify_openblas_install() {
    python - <<'PY'
import importlib.util
for pkg in ("scipy_openblas32", "scipy_openblas64"):
    if importlib.util.find_spec(pkg):
        print(f"Detected: {pkg}")
PY
}

main() {
    assert_docker

    require_command "find"
    require_command "cp"
    require_command "mv"
    require_command "sphinx_gallery_py2jupyter"

    prepare_workspace
    backup_required_content
    generate_notebooks
    restore_binder_assets
    setup_symlinks

    install_openblas_variant || true
    log "postBuild completed successfully."
}

main "$@"
