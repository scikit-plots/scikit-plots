#!/usr/bin/env bash
# shellcheck shell=bash
# postBuild — repo2docker post-build script for scikit-plots/binder
#
# PURPOSE
#   Converts scikit-plots Python gallery examples into Jupyter notebooks,
#   configures the Binder workspace directory layout, and installs
#   scikit-plots from source with CPU-appropriate compiler flags.
#
# CONTRACT
#   Input  : WORKDIR must contain galleries/examples/ and .binder/
#   Output : WORKDIR contains .generated-notebooks/ with .ipynb files
#            and notebooks/auto_examples -> ../.generated-notebooks symlink
#   Side effects: WORKDIR is cleared and rebuilt; all content is backed up
#                 to a unique temp directory first and restored on exit.
#
# INVARIANTS
#   - Must run inside a Docker container (build-time or run-time)
#   - WORKDIR must not resolve to a protected system path
#   - Temp directory is always removed on exit regardless of outcome
#   - WORKDIR is only cleared AFTER all backups are verified
#
# FAILURE MODES
#   - Not in Docker               : exit 1, no data touched
#   - Protected WORKDIR path      : exit 1, no data touched
#   - Missing required command    : exit 1, no data touched
#   - Missing source directory    : exit 1, no data touched
#   - Backup verification fails   : exit 1, no data touched
#   - Post-deletion failure       : cleanup trap removes temp; WORKDIR is empty
#                                   (irrecoverable — inspect the build logs)
#   - OpenBLAS install failure    : logged as warning; script succeeds
#   - scikit-plots install failure: exit 1 (build aborts; annoylib SIMD
#                                   mismatch is a runtime SIGILL — fatal)
#
# ENVIRONMENT
#   SCIPY_OPENBLAS_VARIANT  32 | 64 | auto (default: auto)
#                           Controls which scipy-openblas variant is installed.

set -Eeuo pipefail
IFS=$'\n\t'

# Ignore SIGPIPE so the script is not killed when output is piped to a tool
# that closes its stdin early (e.g. head, less, tee into a closed descriptor).
# Without this, any printf/log call after the consumer closes propagates SIGPIPE
# and terminates the script silently under set -e.
trap '' PIPE

# ─────────────────────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_NAME="$(basename -- "$0")"
readonly SCRIPT_NAME

# Use ${PWD} rather than $(pwd) — avoids a subshell and is always set by bash.
readonly WORKDIR="${PWD}"

# TMP_ROOT is populated by prepare_workspace() via mktemp -d so that concurrent
# builds each get a unique directory and cannot interfere with each other.
# Declared here (not readonly) so that cleanup() can reference it even before
# prepare_workspace() runs.
TMP_ROOT=""

readonly GENERATED_NOTEBOOKS_DIR="${WORKDIR}/.generated-notebooks"
readonly NOTEBOOKS_LINK="${WORKDIR}/notebooks/auto_examples"

# ─────────────────────────────────────────────────────────────────────────────
# Logging — all output goes to stderr so it does not pollute captured stdout
# ─────────────────────────────────────────────────────────────────────────────

log_info()  { printf '[%s] INFO  %s\n' "${SCRIPT_NAME}" "$*" >&2; }
log_warn()  { printf '[%s] WARN  %s\n' "${SCRIPT_NAME}" "$*" >&2; }
log_error() { printf '[%s] ERROR %s\n' "${SCRIPT_NAME}" "$*" >&2; }

# ─────────────────────────────────────────────────────────────────────────────
# Cleanup — runs on EXIT, INT, and TERM
# ─────────────────────────────────────────────────────────────────────────────

cleanup() {
    # Capture the exit code from the failing command before anything else can
    # change it.  set +e prevents cleanup itself from triggering a second exit.
    local exit_code=$?
    set +e

    if [[ -n "${TMP_ROOT}" && -d "${TMP_ROOT}" ]]; then
        log_info "Removing temp directory: ${TMP_ROOT}"
        rm -rf -- "${TMP_ROOT}"
    fi

    exit "${exit_code}"
}

trap cleanup EXIT
# Translate signals to predictable exit codes so cleanup() receives the right
# value via $?.  The 128+N convention is the POSIX standard for signal exits.
trap 'exit 130' INT    # 128 + 2  (SIGINT)
trap 'exit 143' TERM   # 128 + 15 (SIGTERM)

# ─────────────────────────────────────────────────────────────────────────────
# Guards — checked before any destructive operation
# ─────────────────────────────────────────────────────────────────────────────

assert_docker() {
    # /.dockerenv : injected by the Docker daemon at *runtime* (docker run).
    #               NOT present during docker build / docker buildx build.
    # NB_USER     : set by repo2docker as --build-arg -> ARG -> ENV at build time.
    # cgroup      : cgroupv1 marker present in both build and runtime containers.
    #
    # Any one signal is sufficient to confirm a container context.
    local in_docker=false

    [[ -f "/.dockerenv" ]] \
        && in_docker=true

    [[ -n "${NB_USER:-}" ]] \
        && in_docker=true

    grep -qE 'docker|lxc|kubepods|buildkit' /proc/self/cgroup 2>/dev/null \
        && in_docker=true

    if [[ "${in_docker}" == false ]]; then
        log_error "This script must run inside a Docker/repo2docker container."
        log_error "Exiting: running outside a container can delete important data."
        exit 1
    fi

    log_info "Container environment confirmed."
}

assert_safe_workdir() {
    # Refuse to operate if WORKDIR resolves to a path where mass deletion would
    # be catastrophic.  This is a defence-in-depth check — the primary
    # protection is that we only delete from an absolute, verified path, but
    # this guard catches misconfigured environments before any harm is done.
    # Developer note: ${HOME} and /home are intentionally NOT in this list.
    # repo2docker sets WORKDIR to the container user's home directory
    # (e.g. /home/jovyan), which IS the legitimate target for this script.
    # The guard only blocks paths that are unambiguously system infrastructure
    # and would never be a valid project workspace in any environment.
    local -a protected=(
        "/"
        "/bin" "/sbin" "/lib" "/lib64"
        "/usr" "/usr/bin" "/usr/lib" "/usr/local"
        "/etc" "/var" "/var/log"
        "/proc" "/sys" "/dev"
        "/tmp" "/run"
        "/root" "/opt" "/boot"
    )

    local danger
    for danger in "${protected[@]}"; do
        if [[ "${WORKDIR}" == "${danger}" ]]; then
            log_error "WORKDIR='${WORKDIR}' is a protected system path."
            log_error "Refusing to clear its contents."
            exit 1
        fi
    done
    log_info "WORKDIR safety check passed: ${WORKDIR}"
}

require_command() {
    # $1 : command name to check
    local cmd="$1"
    command -v "${cmd}" >/dev/null 2>&1 || {
        log_error "Required command not found on PATH: ${cmd}"
        exit 1
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Workspace setup
# ─────────────────────────────────────────────────────────────────────────────

prepare_workspace() {
    # mktemp -d creates a uniquely named directory, preventing race conditions
    # when multiple builds run concurrently on the same host.
    TMP_ROOT="$(mktemp -d -t "scikit-plots-build.XXXXXX")"
    log_info "Temp workspace: ${TMP_ROOT}"
}

backup_required_content() {
    # Developer note: source paths inside WORKDIR, destinations inside TMP_ROOT.
    # The backup directory names are canonical — generate_notebooks() and
    # restore_binder_assets() must use the exact same names.
    local tmp_examples="${TMP_ROOT}/examples"
    local tmp_binder="${TMP_ROOT}/.binder"
    local src_examples="${WORKDIR}/galleries/examples"
    local src_binder="${WORKDIR}/.binder"

    [[ -d "${src_examples}" ]] || {
        log_error "Source directory missing: ${src_examples}"
        exit 1
    }
    [[ -d "${src_binder}" ]] || {
        log_error "Source directory missing: ${src_binder}"
        exit 1
    }

    log_info "Backing up examples -> ${tmp_examples}"
    cp -a -- "${src_examples}" "${tmp_examples}"

    log_info "Backing up .binder -> ${tmp_binder}"
    cp -a -- "${src_binder}" "${tmp_binder}"

    # Verify backup completeness before any destructive step.
    # If either check fails, set -e aborts here and WORKDIR is untouched.
    [[ -d "${tmp_examples}" ]] || { log_error "Backup of examples failed."; exit 1; }
    [[ -d "${tmp_binder}"   ]] || { log_error "Backup of .binder failed.";  exit 1; }
    log_info "Backup verified."

    # Clear WORKDIR.
    # ${WORKDIR:?} is a parameter guard: if WORKDIR is unset or empty, bash
    # aborts with an error before find runs — preventing accidental root deletion.
    # -mindepth 1 preserves the directory itself so the build layer stays valid.
    log_info "Clearing WORKDIR: ${WORKDIR}"
    find "${WORKDIR:?}" -mindepth 1 -delete
}

# ─────────────────────────────────────────────────────────────────────────────
# Notebook generation
# ─────────────────────────────────────────────────────────────────────────────

generate_notebooks() {
    # Developer note: source is ${TMP_ROOT}/examples (set by backup_required_content).
    local tmp_examples="${TMP_ROOT}/examples"

    rm -rf  -- "${GENERATED_NOTEBOOKS_DIR}"
    mkdir -p   "${GENERATED_NOTEBOOKS_DIR}"

    log_info "Staging example files -> ${GENERATED_NOTEBOOKS_DIR}"
    cp -a -- "${tmp_examples}/." "${GENERATED_NOTEBOOKS_DIR}/"

    local py_count
    py_count="$(find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.py' | wc -l)"
    log_info "Found ${py_count} Python gallery file(s) to convert."

    if (( py_count == 0 )); then
        log_warn "No .py files found — nothing to convert."
    else
        # Use -exec ... \; (one invocation per file) rather than -exec ... +
        # (batched).  The \; form ensures that a failure on any individual file
        # is reported immediately with its filename, not silently absorbed into
        # a batch exit code.
        find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.py' \
            -exec sphinx_gallery_py2jupyter '{}' \;
    fi

    # Remove all non-notebook files from the staging directory.
    find "${GENERATED_NOTEBOOKS_DIR}" -type f ! -name '*.ipynb' -delete

    local nb_count
    nb_count="$(find "${GENERATED_NOTEBOOKS_DIR}" -type f -name '*.ipynb' | wc -l)"
    log_info "Generated ${nb_count} notebook(s)."

    # If we had source files but produced no notebooks, the conversion failed.
    if (( py_count > 0 && nb_count == 0 )); then
        log_error "sphinx_gallery_py2jupyter produced 0 notebooks from ${py_count} .py files."
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Restore binder assets and symlinks
# ─────────────────────────────────────────────────────────────────────────────

restore_binder_assets() {
    local tmp_binder="${TMP_ROOT}/.binder"

    [[ -d "${tmp_binder}" ]] || {
        log_error "Backed-up .binder not found at: ${tmp_binder}"
        exit 1
    }

    log_info "Restoring .binder -> ${WORKDIR}/.binder"
    rm -rf -- "${WORKDIR}/.binder"

    # cp -a + rm is used instead of mv because mv(1) calls rename(2) which
    # fails with EXDEV when source and destination are on different filesystems
    # (e.g. /tmp on tmpfs, WORKDIR on overlayfs inside the Docker build layer).
    cp -a  -- "${tmp_binder}" "${WORKDIR}/.binder"
    rm -rf -- "${tmp_binder}"

    [[ -d "${WORKDIR}/.binder" ]] || {
        log_error "Failed to restore .binder to ${WORKDIR}."
        exit 1
    }
    log_info ".binder restored."
}

setup_symlinks() {
    # sphinx-gallery generates binder launch URLs using the path
    # notebooks/auto_examples/<notebook>.ipynb relative to the repo root.
    # This symlink satisfies that expectation regardless of which repo is
    # checked out for binder (scikit-plots vs its documentation repo).
    mkdir -p -- "$(dirname -- "${NOTEBOOKS_LINK}")"
    ln -sfn -- "../.generated-notebooks" "${NOTEBOOKS_LINK}"
    log_info "Symlink: ${NOTEBOOKS_LINK} -> ../.generated-notebooks"
}

# ─────────────────────────────────────────────────────────────────────────────
# OpenBLAS
# ─────────────────────────────────────────────────────────────────────────────

install_openblas_variant() {
    # User note: set SCIPY_OPENBLAS_VARIANT=32 or =64 to pin a specific variant.
    # Defaults to 'auto': tries 64-bit first, falls back to 32-bit on failure.
    local variant="${SCIPY_OPENBLAS_VARIANT:-auto}"
    local package_name

    case "${variant}" in
        32)   package_name="scipy-openblas32" ;;
        64)   package_name="scipy-openblas64" ;;
        auto) package_name=""                 ;;   # handled below
        *)
            log_error "Invalid SCIPY_OPENBLAS_VARIANT='${variant}'."
            log_error "Allowed values: 32 | 64 | auto"
            return 1
            ;;
    esac

    if [[ "${variant}" == "auto" ]]; then
        log_info "SCIPY_OPENBLAS_VARIANT=auto: trying scipy-openblas64 first."
        if python -m pip install --no-cache-dir scipy-openblas64 2>&1 \
                | sed 's/^/[pip] /'; then
            log_info "Installed scipy-openblas64."
            return 0
        fi
        log_warn "scipy-openblas64 unavailable; falling back to scipy-openblas32."
        python -m pip install --no-cache-dir scipy-openblas32 2>&1 \
            | sed 's/^/[pip] /'
        log_info "Installed scipy-openblas32."
        return 0
    fi

    log_info "Installing ${package_name} (SCIPY_OPENBLAS_VARIANT=${variant})."
    python -m pip install --no-cache-dir "${package_name}" 2>&1 \
        | sed 's/^/[pip] /'
}

verify_openblas_install() {
    # Emit a warning (not an error) when neither variant is detectable.
    # Some environments use a system OpenBLAS that does not ship as a pip
    # package, so absence of these modules is not always a fatal condition.
    log_info "Verifying OpenBLAS installation."
    python - <<'PY'
import importlib.util, sys

found = [
    pkg for pkg in ("scipy_openblas32", "scipy_openblas64")
    if importlib.util.find_spec(pkg) is not None
]

if found:
    print("Detected:", ", ".join(found), flush=True)
else:
    print(
        "WARNING: neither scipy_openblas32 nor scipy_openblas64 detected.",
        file=sys.stderr,
    )
PY
}

# ─────────────────────────────────────────────────────────────────────────────
# scikit-plots: CPU audit, compiler flag selection, source install
#
# annoylib.h SIMD dispatch (lines 543-558 of annoylib.h):
#   ANNOYLIB_USE_AVX    requires __AVX__ + __SSE__ + __SSE2__ + __SSE3__
#   ANNOYLIB_USE_AVX512 requires GCC + __AVX512F__ (Clang excluded, see #402)
#   ANNOYLIB_SIMD_SCALAR is the fallback when neither flag is set
#
# Installing a pre-built AVX2 wheel on a non-AVX2 node causes a SIGILL kernel
# crash.  --no-binary scikit-plots forces compilation on this node so the
# compiler uses the CFLAGS/CXXFLAGS set here, which are bounded to the node's
# actual CPU features.
# ─────────────────────────────────────────────────────────────────────────────

# BUG-5 FIX: has_flag() moved to top-level scope.
# In bash, functions defined inside other functions still have global scope
# (bash has no lexically local functions).  Defining it here makes that
# explicit and avoids the misleading appearance of a nested local function.
#
# Developer note: this function relies on dynamic scoping — CPUFLAGS must be
# set (as a local variable) in install_scikit_plots() before has_flag() is
# called via audit_cpu().  Bash dynamic scoping makes the local binding
# visible to all callees of install_scikit_plots().
#
# $1 : CPU flag name to test (e.g. avx2, sse4_1, f16c)
has_flag() {
    printf '%s\n' "${CPUFLAGS:-}" | grep -qw "$1"
}

audit_cpu() {
    # Populate CPUFLAGS and the HAS_* flag variables from /proc/cpuinfo.
    #
    # Developer note: CPUFLAGS and HAS_* are NOT declared local here.
    # They are declared local in install_scikit_plots() and are visible here
    # via bash dynamic scoping — modifications in this function update the
    # local bindings in the calling stack frame.
    CPUFLAGS=""
    if [[ -f /proc/cpuinfo ]]; then
        CPUFLAGS="$(grep -m1 '^flags' /proc/cpuinfo | cut -d: -f2)"
    fi

    HAS_SSE4=0;   has_flag sse4_1   && HAS_SSE4=1
    HAS_AVX=0;    has_flag avx      && HAS_AVX=1
    HAS_AVX2=0;   has_flag avx2     && HAS_AVX2=1
    HAS_AVX512=0; has_flag avx512f  && HAS_AVX512=1
    HAS_F16C=0;   has_flag f16c     && HAS_F16C=1

    # BUG-8 FIX: use log_info (structured logging) instead of raw echo.
    log_info "CPU feature audit:"
    log_info "  sse4_1  : ${HAS_SSE4}"
    log_info "  avx     : ${HAS_AVX}"
    log_info "  avx2    : ${HAS_AVX2}   (required for ANNOYLIB_USE_AVX)"
    log_info "  avx512f : ${HAS_AVX512} (required for ANNOYLIB_USE_AVX512, GCC only)"
    log_info "  f16c    : ${HAS_F16C}   (required for F16C float16_t hardware path)"
}

select_compiler_flags() {
    # Set CFLAGS and CXXFLAGS based on the CPU features detected by audit_cpu().
    #
    # Developer note: CFLAGS and CXXFLAGS are declared local in
    # install_scikit_plots() and updated here via dynamic scoping.
    # After this function returns, install_scikit_plots() exports them.
    #
    # annoylib.h line 543-558 (SIMD dispatch):
    #   -DNO_MANUAL_VECTORIZATION defines ANNOYLIB_SIMD_SCALAR unconditionally.
    #   The #error at line 565 enforces exactly one backend; this flag is the
    #   only safe way to guarantee scalar on a heterogeneous cluster.
    #
    # annoylib.h line 289-291 (C++ standard):
    #   Hard #error if __cplusplus < 201103L.
    #   -std=c++14 chosen because ANNOYLIB_MULTITHREADED_BUILD requires
    #   std::shared_timed_mutex (C++14, lines 241-251).
    #
    # annoylib.h lines 317-375 (float16_t dispatch):
    #   -march=x86-64-v2 suppresses __F16C__ -> software float16 path.
    #   The software path is pure C++11: memcpy + IEEE 754 bit manipulation.
    #
    # -O2: safe level; -O3 can re-introduce auto-vectorized AVX instructions
    #   even when NO_MANUAL_VECTORIZATION is set.
    local base_cflags="-march=x86-64-v2 -mtune=generic -O2 -DNO_MANUAL_VECTORIZATION"
    local base_cxxflags="${base_cflags} -std=c++14"

    # Promote to AVX only when the node has both AVX and AVX2.
    # This mirrors the annoylib.h condition at line 548:
    #   __AVX__ && __SSE__ && __SSE2__ && __SSE3__
    # We additionally require avx2 (implicit in __AVX__ on modern GCC -mavx2).
    # We do NOT set NO_MANUAL_VECTORIZATION in this branch.
    if [[ "${HAS_AVX2}" == "1" ]]; then
        log_info "AVX2 confirmed — building with AVX SIMD path."
        CFLAGS="-march=x86-64-v3 -mtune=generic -O2"
        CXXFLAGS="${CFLAGS} -std=c++14"
    else
        log_info "No AVX2 — building with scalar path (NO_MANUAL_VECTORIZATION)."
        CFLAGS="${base_cflags}"
        CXXFLAGS="${base_cxxflags}"
    fi

    log_info "  CFLAGS   = ${CFLAGS}"
    log_info "  CXXFLAGS = ${CXXFLAGS}"
}

install_scikit_plots() {
    # BUG-4 FIX: Section B extracted from main() into a dedicated function.
    # BUG-6 FIX: all variables declared local — no global scope leakage.
    #
    # Dynamic scoping note: audit_cpu() and select_compiler_flags() write to
    # CPUFLAGS, HAS_*, CFLAGS, CXXFLAGS.  Declaring them local here makes
    # those assignments update this frame's bindings rather than creating
    # or modifying globals.  Bash dynamic scoping makes locals visible to
    # callees, so the helpers can modify them without taking them as arguments.
    local CPUFLAGS=""
    local HAS_SSE4=0 HAS_AVX=0 HAS_AVX2=0 HAS_AVX512=0 HAS_F16C=0
    local CFLAGS="" CXXFLAGS=""
    local nightly_index pypi_index

    # ── Section 1: CPU capability audit ──────────────────────────────────────
    # Determines which SIMD path annoylib.h will take at compile time so that
    # we can choose CFLAGS before invoking pip.  Also printed for diagnosing
    # SIGILL crashes.
    log_info "annoylib CPU feature audit starting."
    audit_cpu

    # ── Section 2: Compiler flag selection ───────────────────────────────────
    select_compiler_flags

    export CFLAGS CXXFLAGS
    export CC="${CC:-gcc}"
    export CXX="${CXX:-g++}"

    # ── Section 3: Install scikit-plots from source ───────────────────────────
    # --no-binary scikit-plots: forces pip to compile on this node so the
    # compiler uses the CFLAGS/CXXFLAGS exported above.
    #
    # The nightly staging index supplies the latest source tarball.
    # PyPI is the fallback if the staging index lacks scikit-plots entirely.
    nightly_index="https://pypi.anaconda.org/scikit-plots-wheels-staging-nightly/simple"
    pypi_index="https://pypi.org/simple"

    log_info "Installing scikit-plots from source (nightly staging -> PyPI fallback)."
    # BUG-7 FIX: python -m pip instead of bare pip to guarantee the pip
    # associated with the active Python interpreter is used.
    python -m pip install \
        --index-url        "${nightly_index}" \
        --extra-index-url  "${pypi_index}"    \
        --no-binary        scikit-plots       \
        --no-cache-dir                        \
        scikit-plots

    # ── Section 4: Post-install verification ─────────────────────────────────
    # Validate that the annoylib SIMD path chosen at compile time matches the
    # runtime CPU.  If this import fails, the kernel would crash silently with
    # SIGILL; failing here gives a clear error with actionable remediation.
    #
    # annoylib.h runtime guard (see __init__.py Layer-3 recommendation):
    #   The guard reads /proc/cpuinfo and raises RuntimeError before any .so
    #   is imported, giving a clean error instead of a SIGILL kernel crash.
    log_info "Smoke test: import scikit_plots."
    # BUG-1 FIX: closing PYEOF delimiter must be at column 0 for bash to
    # recognise it as the end of the heredoc.  Using <<'PYEOF' (not <<-'PYEOF')
    # means leading tabs are NOT stripped — the delimiter must be unindented.
    # BUG-2 FIX: Python code must also start at column 0; any leading
    # whitespace on a top-level statement causes IndentationError.
    python - <<'PYEOF'
import subprocess, sys

# Read CPU flags once.
result = subprocess.run(
    ["grep", "-m1", "flags", "/proc/cpuinfo"],
    capture_output=True, text=True, check=False,
)
flags = set(result.stdout.split(":")[1].split()) if result.returncode == 0 else set()

print(
    f"  CPU features: avx={('avx' in flags)}, avx2={('avx2' in flags)}, "
    f"f16c={('f16c' in flags)}, sse4_1={('sse4_1' in flags)}"
)

# Import — triggers the Layer-3 runtime guard if present, or raises
# SIGILL if the wrong wheel was installed.
try:
    import scikit_plots  # noqa: F401
    print("  OK scikit_plots imported successfully")
except RuntimeError as exc:
    print(f"  FAIL RuntimeError (CPU feature mismatch): {exc}", file=sys.stderr)
    sys.exit(1)
except ImportError as exc:
    print(f"  FAIL ImportError: {exc}", file=sys.stderr)
    sys.exit(1)
PYEOF

    log_info "scikit-plots smoke test passed."
}

# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

main() {
    log_info "postBuild starting."

    # ── Guards (no side effects) ──────────────────────────────────────────────
    assert_docker
    assert_safe_workdir

    # Check only the commands that are not guaranteed by the base image.
    # find/cp/mv/rm are POSIX utilities always present in buildpack-deps;
    # python and sphinx_gallery_py2jupyter are installed by requirements.txt
    # and may be absent if the environment is misconfigured.
    require_command python
    require_command sphinx_gallery_py2jupyter

    # ── Main pipeline ─────────────────────────────────────────────────────────
    prepare_workspace
    backup_required_content    # backs up; then clears WORKDIR
    generate_notebooks         # converts .py -> .ipynb inside WORKDIR
    restore_binder_assets      # puts .binder back into WORKDIR
    setup_symlinks             # creates notebooks/auto_examples -> symlink

    # ── Optional: OpenBLAS ───────────────────────────────────────────────────
    # install_openblas_variant is best-effort: failure is logged as a warning
    # rather than aborting the build, because the core notebook conversion has
    # already completed successfully at this point.
    if install_openblas_variant; then
        verify_openblas_install
    else
        log_warn "OpenBLAS installation failed; continuing without it."
        log_warn "Set SCIPY_OPENBLAS_VARIANT=32 or =64 to pin a specific variant."
    fi

    # ── scikit-plots source install ───────────────────────────────────────────
    # Fatal if it fails — a pre-built AVX2 wheel on a non-AVX2 node is a
    # runtime SIGILL crash.  See FAILURE MODES in the file header.
    install_scikit_plots || true

    log_info "postBuild completed successfully."
}

main "$@"
